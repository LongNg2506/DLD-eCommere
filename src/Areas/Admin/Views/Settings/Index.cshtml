@model MyProject.Areas.Admin.ViewModels.SettingsAdminViewModel
@{
    ViewData["Title"] = "Store Settings";
}

<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h1 class="admin-page-title">Store Settings</h1>
        <p class="admin-page-subtitle">Manage store information and configuration</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="admin-alert admin-alert-success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>@TempData["Success"]</span>
    </div>
}

<form asp-action="Index" method="post" class="admin-form">
    @Html.AntiForgeryToken()
    <div class="admin-form-grid">
        <div class="admin-form-card">
            <div class="admin-form-card-header">
                <h3>Store Information</h3>
            </div>
            <div class="admin-form-card-body">
                <div class="admin-form-group">
                    <label class="admin-form-label">Store Name</label>
                    <input asp-for="StoreName" class="admin-form-control" placeholder="DLD Watch Store" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-form-label">Address</label>
                    <input asp-for="StoreAddress" class="admin-form-control" placeholder="123 Đường ABC, TP.HCM" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-form-label">Phone Number</label>
                    <input asp-for="StorePhone" class="admin-form-control" placeholder="0901234567" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-form-label">Store Email</label>
                    <input asp-for="StoreEmail" class="admin-form-control" type="email" placeholder="contact@dldstore.com" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-form-label">Contact Email</label>
                    <input asp-for="ContactEmail" class="admin-form-control" type="email" placeholder="support@dldstore.com" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-form-label">Store Description</label>
                    <textarea asp-for="StoreDescription" class="admin-form-control admin-form-textarea" rows="3" placeholder="Brief description of the store..."></textarea>
                </div>
            </div>
        </div>

        <div class="admin-form-card">
            <div class="admin-form-card-header">
                <h3>Social Media</h3>
            </div>
            <div class="admin-form-card-body">
                <div class="admin-form-group">
                    <label class="admin-form-label">Facebook</label>
                    <input asp-for="FacebookUrl" class="admin-form-control" placeholder="https://facebook.com/..." />
                </div>
                <div class="admin-form-group">
                    <label class="admin-form-label">Instagram</label>
                    <input asp-for="InstagramUrl" class="admin-form-control" placeholder="https://instagram.com/..." />
                </div>
                <div class="admin-form-group">
                    <label class="admin-form-label">Zalo</label>
                    <input asp-for="ZaloUrl" class="admin-form-control" placeholder="https://zalo.me/..." />
                </div>
            </div>
            <div class="admin-form-card-footer">
                <button type="submit" class="admin-btn admin-btn-primary">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Save Settings
                </button>
            </div>
        </div>
    </div>
</form>