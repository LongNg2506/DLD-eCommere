@{
    ViewData["Title"] = "Payment Successful";
    Layout = "_Layout";
}

<div class="page-container">
    <div class="container" style="max-width: 600px;">
        <div class="payment-success-card">
            <div class="success-icon">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>
            <h1>Payment Successful!</h1>
            <p class="success-subtitle">Your order has been placed successfully.</p>

            <div class="success-details">
                <div class="success-row">
                    <span class="success-label">Invoice</span>
                    <span class="success-value">@ViewBag.InvoiceNumber</span>
                </div>
                <div class="success-row">
                    <span class="success-label">Order ID</span>
                    <span class="success-value">#@ViewBag.OrderId</span>
                </div>
                <div class="success-row">
                    <span class="success-label">Total</span>
                    <span class="success-value success-amount">@(((decimal)ViewBag.Amount).ToString("N0")) VND</span>
                </div>
            </div>

            <a asp-controller="Home" asp-action="Index" class="back-home-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Back to Home
            </a>
        </div>
    </div>
</div>

<style>
.payment-success-card {
    background: var(--bg-secondary);
    border-radius: 20px;
    padding: 48px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
}
.success-icon {
    color: var(--accent);
}
.payment-success-card h1 {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0;
}
.success-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    margin: 0;
}
.success-details {
    width: 100%;
    background: var(--bg-primary);
    border-radius: 14px;
    padding: 24px;
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 14px;
}
.success-row {
    display: flex;
    justify-content: space-between;
}
.success-label {
    color: var(--text-secondary);
    font-size: 0.95rem;
}
.success-value {
    font-weight: 600;
    color: var(--text-primary);
}
.success-amount {
    color: var(--accent);
    font-size: 1.15rem;
}
.back-home-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--accent);
    color: #111;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
}
.back-home-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(169,206,194,0.35);
    color: #111;
}
@@media (max-width: 576px) {
    .payment-success-card { padding: 32px 20px; }
    .payment-success-card h1 { font-size: 1.3rem; }
}
</style>
