@model MyProject.Controllers.ShopProductDetailViewModel

@{
    ViewData["Title"] = Model.Product.Name;
}

<!-- Product Detail Hero -->
<section class="pdetail-hero">
    <div class="container">
        <div class="pdetail-hero-inner">
            <nav aria-label="breadcrumb">
                <ol class="pdetail-breadcrumb">
                    <li><a href="@Url.Action("Index", "Shop")">Shop</a></li>
                    <li>/</li>
                    <li><a href="@Url.Action("Index", "Shop", new { categories = Model.Product.CategoryId })">@Model.Product.CategoryName</a></li>
                    <li>/</li>
                    <li>@Model.Product.Name</li>
                </ol>
            </nav>
        </div>
    </div>
</section>

<!-- Product Detail Content -->
<section class="pdetail-content">
    <div class="container">
        <div class="pdetail-grid">

            <!-- Images -->
            <div class="pdetail-images">
                <div class="pdetail-main-image" id="mainImage">
                    @if (!string.IsNullOrWhiteSpace(Model.Product.ImageUrl))
                    {
                        <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" id="mainImageImg" />
                    }
                    else
                    {
                        <div class="product-placeholder-img">
                            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--border)" stroke-width="1.5" stroke-linecap="round">
                                <circle cx="12" cy="12" r="10"/><path d="M12 6V12L16 14"/>
                            </svg>
                        </div>
                    }
                </div>

                @if (Model.Product.GalleryList.Count > 0)
                {
                    <div class="pdetail-thumbnails">
                        @{
                            int thumbIdx = 0;
                        }
                        @foreach (var thumb in Model.Product.GalleryList)
                        {
                            <button class="pdetail-thumb @(thumbIdx == 0 ? "active" : "")"
                                    onclick="changeMainImage('@thumb', this)"
                                    aria-label="View image @(thumbIdx + 1)">
                                <img src="@thumb" alt="Thumbnail @(thumbIdx + 1)" />
                            </button>
                            thumbIdx++;
                        }
                    </div>
                }
            </div>

            <!-- Info -->
            <div class="pdetail-info">
                @if (Model.Product.Badge != "none")
                {
                    <div class="pdetail-badges">
                        @if (Model.Product.Badge == "sale")
                        {
                            <span class="badge-pill badge-sale">-@Model.Product.Discount%</span>
                        }
                        else if (Model.Product.Badge == "new")
                        {
                            <span class="badge-pill badge-new">New</span>
                        }
                        else if (Model.Product.Badge == "hot")
                        {
                            <span class="badge-pill badge-hot">Hot</span>
                        }
                    </div>
                }

                <div class="pdetail-category">@Model.Product.CategoryName</div>
                <h1 class="pdetail-title">@Model.Product.Name</h1>

                <div class="pdetail-rating">
                    <span class="stars">
                        @for (int i = 0; i < 5; i++)
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="@(i < 4 ? "#ffc107" : "none")" stroke="#ffc107" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        }
                    </span>
                    <span class="rating-count">(128 reviews)</span>
                </div>

                <div class="pdetail-price">
                    <span class="price-current">$@Model.Product.SalePrice.ToString("N0")</span>
                    @if (Model.Product.Discount > 0)
                    {
                        <span class="price-original">$@Model.Product.Price.ToString("N0")</span>
                        <span class="price-discount">-@Model.Product.Discount%</span>
                    }
                </div>

                <div class="pdetail-description">
                    <p>@Model.Product.Description</p>
                </div>

                <div class="pdetail-stock">
                    @if (Model.Product.StockQuantity > 0)
                    {
                        <div class="pdetail-stock-status in-stock">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                            In Stock (@Model.Product.StockQuantity available)
                        </div>
                    }
                    else
                    {
                        <div class="pdetail-stock-status out-stock">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                            Out of Stock
                        </div>
                    }
                </div>

                <div class="pdetail-actions">
                    <div class="pdetail-qty">
                        <button class="qty-btn" onclick="changeDetailQty(-1)">−</button>
                        <input type="number" id="detailQty" value="1" min="1" max="@Model.Product.StockQuantity" />
                        <button class="qty-btn" onclick="changeDetailQty(1)">+</button>
                    </div>
                    @if (Model.Product.StockQuantity > 0)
                    {
                        <button class="add-to-cart-btn" onclick="addToCart(@Model.Product.Id, '@Model.Product.Name.Replace("'", "\\'")', @Model.Product.SalePrice, @Model.Product.Price, @Model.Product.Discount)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                            Add to Cart
                        </button>
                    }
                    <button class="pdetail-wishlist-btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Related Products -->
@if (Model.RelatedProducts.Count > 0)
{
    <section class="section-padding related-products">
        <div class="container">
            <div class="section-header-centered">
                <h2 class="section-title">You May Also Like</h2>
                <p class="section-subtitle">Explore more premium timepieces</p>
            </div>
            <div class="shop-product-grid">
                @foreach (var product in Model.RelatedProducts)
                {
                    <div class="product-card">
                        <div class="product-image-wrap">
                            @if (product.Badge != "none")
                            {
                                <div class="product-badges">
                                    @if (product.Badge == "sale")
                                    {
                                        <span class="badge-pill badge-sale">-@product.Discount%</span>
                                    }
                                    else if (product.Badge == "new")
                                    {
                                        <span class="badge-pill badge-new">New</span>
                                    }
                                    else if (product.Badge == "hot")
                                    {
                                        <span class="badge-pill badge-hot">Hot</span>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" loading="lazy"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="product-placeholder-img" style="display:none">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6V12L16 14"/></svg>
                                </div>
                            }
                            else
                            {
                                <div class="product-placeholder-img">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6V12L16 14"/></svg>
                                </div>
                            }
                        </div>
                        <div class="product-info">
                            <div class="product-category">@product.CategoryName</div>
                            <h3 class="product-name">
                                <a href="@Url.Action("ProductDetail", "Shop", new { id = product.Id })">@product.Name</a>
                            </h3>
                            <div class="product-price">
                                <span class="price-current">$@product.SalePrice.ToString("N0")</span>
                                @if (product.Discount > 0)
                                {
                                    <span class="price-original">$@product.Price.ToString("N0")</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@section Scripts {
    <script>
        function changeDetailQty(delta) {
            var input = document.getElementById('detailQty');
            var val = parseInt(input.value) + delta;
            if (val >= 1 && val <= parseInt(input.max)) {
                input.value = val;
            }
        }

        function changeMainImage(url, btn) {
            var mainImg = document.getElementById('mainImageImg');
            if (mainImg) {
                mainImg.src = url;
            }
            document.querySelectorAll('.pdetail-thumb').forEach(function(t) {
                t.classList.remove('active');
            });
            if (btn) {
                btn.classList.add('active');
            }
        }
    </script>
}