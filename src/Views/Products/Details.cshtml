@model MyProject.DTOs.Products.ProductListItemDto

@{
    ViewData["Title"] = "Product Details";
}

<h1 class="mb-4">Product Details</h1>

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded shadow" />
        }
        else
        {
            <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="width:100%;height:300px;font-size:14px;">No Image</div>
        }
    </div>
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">Product ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Product Name</dt>
            <dd class="col-sm-9 fw-bold">@Model.Name</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.CategoryName</dd>

            <dt class="col-sm-3">Original Price</dt>
            <dd class="col-sm-9">@Model.Price.ToString("N0") ₫</dd>

            <dt class="col-sm-3">Discount</dt>
            <dd class="col-sm-9">
                @if (Model.Discount > 0)
                {
                    <span class="badge bg-danger">@Model.Discount%</span>
                }
                else
                {
                    <span class="text-muted">No discount</span>
                }
            </dd>

            <dt class="col-sm-3">Sale Price</dt>
            <dd class="col-sm-9 fs-5 fw-bold text-success">@Model.SalePrice.ToString("N0") ₫</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">
                <span class="@(Model.StockQuantity > 0 ? "text-success" : "text-danger") fw-bold">
                    @Model.StockQuantity
                </span>
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Selling</span>
                }
                else
                {
                    <span class="badge bg-secondary">Discontinued</span>
                }
            </dd>

            <dt class="col-sm-3">Created Date</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrEmpty(Model.Description) ? "No description." : Model.Description)
            </dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
