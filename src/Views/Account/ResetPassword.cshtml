@model string
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Reset Your Password</h2>
            <p>Please enter a new secure password for your account.</p>
        </div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <div class="form-group mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" name="newPassword" id="newPassword" class="form-control" required minlength="6" />
            </div>

            <div class="form-group mb-4">
                <label for="confirmPassword" class="form-label">Confirm New Password</label>
                <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" required minlength="6" />
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary(true)
                </div>
            }

            <button type="submit" class="btn btn-primary w-100">Update Password</button>
        </form>
    </div>
</div>

<style>
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
    }
    .auth-card {
        width: 100%;
        max-width: 450px;
        padding: 2rem;
        border-radius: 1rem;
        background: var(--surface-color, #fff);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        border: 1px solid var(--border-color, #eee);
    }
    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    .auth-header h2 {
        color: var(--text-main, #5F5C6D);
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .auth-header p {
        color: var(--text-muted, #ACA9BB);
        font-size: 0.9rem;
    }
    .form-control {
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        border: 1px solid var(--border-color, #ddd);
    }
    .btn-primary {
        background-color: var(--primary-color, #A9CEC2);
        border: none;
        padding: 0.75rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-primary:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }
</style>
