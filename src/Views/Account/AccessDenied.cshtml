@{
    ViewData["Title"] = "Access Denied";
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <div class="auth-card" style="text-align:center;max-width:420px">
        <div class="auth-card-header">
            <div style="width:64px;height:64px;border-radius:50%;background:var(--danger);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;opacity:0.9">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <h1 class="auth-title">Access Denied</h1>
            <p class="auth-subtitle">You don't have permission to access this page.</p>
        </div>

        <a asp-controller="Home" asp-action="Index" class="btn-auth-primary" style="display:inline-flex;justify-content:center;margin-top:8px">
            Go to Homepage
        </a>
    </div>
</div>
