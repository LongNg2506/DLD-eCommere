@model string
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card-header">
            <a class="auth-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/Logo-DLD-Light.png" alt="DLD" class="logo-light" style="height:80px;width:auto;display:inline-block;vertical-align:middle;" />
                <img src="~/images/Logo-DLD-Dark.png" alt="DLD" class="logo-dark" style="height:80px;width:auto;display:inline-block;vertical-align:middle;" />
            </a>
            <h1 class="auth-title">Forgot Password</h1>
            <p class="auth-subtitle">Enter your email to receive a reset link</p>
        </div>

        @if (ViewBag.Message != null)
        {
            <div class="success-summary">
                @ViewBag.Message
            </div>
        }

        <form asp-action="ForgotPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="email" class="form-label">Email Address</label>
                <input type="email" name="email" id="email" class="form-control" placeholder="Enter your registered email" autocomplete="email" required />
            </div>

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="error-summary">
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            }

            <button type="submit" class="btn-auth-primary">Send Reset Link</button>
            <a asp-action="Login" class="btn-auth-secondary">Back to Login</a>
        </form>
    </div>
</div>
