@{
    ViewData["Title"] = "About Us";
}

<section class="hero-section" style="min-height:50vh;display:flex;align-items:center;position:relative;overflow:hidden;background:linear-gradient(135deg,var(--accent) 0%,var(--bg-tertiary) 100%);">
    <div class="container">
        <div style="text-align:center;padding:60px 0;position:relative;z-index:2;">
            <span class="section-badge" style="margin-bottom:20px;display:inline-block;background:rgba(255,255,255,0.15);color:#fff;padding:6px 16px;border-radius:20px;font-size:0.8rem;font-weight:500;letter-spacing:0.5px;">Our Story</span>
            <h1 class="inner-hero-title">About DLD</h1>
            <p style="font-size:1.15rem;color:rgba(255,255,255,0.85);max-width:600px;margin:0 auto;">Crafting timeless elegance since 2010. We believe every moment deserves a perfect companion on your wrist.</p>
        </div>
    </div>
    <div style="position:absolute;bottom:-40px;left:0;right:0;height:80px;background:var(--bg-primary);border-radius:50% 50% 0 0;"></div>
</section>

<section style="padding:80px 0;background:var(--bg-primary);">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="section-badge" style="margin-bottom:12px;display:inline-block;">Who We Are</span>
                <h2 style="font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;color:var(--text-primary);margin-bottom:24px;line-height:1.2;">A Legacy of Precision & Passion</h2>
                <p style="color:var(--text-secondary);line-height:1.8;font-size:1.05rem;margin-bottom:20px;">
                    Founded in 2010, DLD began as a small boutique in the heart of the city with a singular vision: to make premium timepieces accessible to everyone who appreciates fine craftsmanship. What started as a passion project by horology enthusiasts has grown into one of the most trusted names in luxury watches.
                </p>
                <p style="color:var(--text-secondary);line-height:1.8;font-size:1.05rem;margin-bottom:20px;">
                    We curate only the finest selections from renowned manufacturers across Switzerland, Japan, and Germany. Each watch in our collection undergoes rigorous quality inspection to ensure it meets our exacting standards.
                </p>
                <p style="color:var(--text-secondary);line-height:1.8;font-size:1.05rem;">
                    Today, we serve over 50,000 customers worldwide, from collectors seeking rare vintage pieces to first-time buyers discovering the joy of owning a quality timepiece.
                </p>
            </div>
            <div class="col-lg-6">
                <div style="position:relative;border-radius:16px;overflow:hidden;aspect-ratio:4/3;background:var(--bg-secondary);">
                    <img src="https://images.unsplash.com/photo-1547996160-81dfa63595aa?w=800&q=80" alt="Luxury watch craftsmanship" style="width:100%;height:100%;object-fit:cover;" />
                    <div style="position:absolute;bottom:20px;right:20px;background:var(--bg-primary);padding:16px 24px;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.15);">
                        <div class="counter-stat" data-target="16" data-suffix="+" style="font-size:2rem;font-weight:700;color:var(--accent);font-family:'Playfair Display',serif;">0</div>
                        <div style="font-size:0.85rem;color:var(--text-secondary);">Years of Excellence</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

